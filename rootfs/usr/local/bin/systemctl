#!/bin/bash

if [ "$UID" != "0" ]; then
  sudo "$0" "$@"
  exit
fi

MY_NAME="${0##*/}"

(
  flock -x -w 5 200

  die ()
  {
    echo "$MY_NAME: $1"
    exit 1
  }

  EXIT_CODE=0


  PARSED_ARGUMENTS="$(getopt -n "$MY_NAME" -o t:p:al --long type:,property:,all,full,value,no-legend,plain -- "$@")" || exit $?

  eval set -- "$PARSED_ARGUMENTS"
  while true; do
    case "$1" in
    -t | --type)
      shift 2
      ;;
    -p | --property)
      IFS="," read -ra PROPERTIES <<< "$2"
      shift 2
      ;;
    -a | --all)
      shift
      ;;
    -l | --full)
      shift
      ;;
    --value)
      VALUE="1"
      shift
      ;;
    --no-legend)
      shift
      ;;
    --plain)
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      die "invalid option -- '$1'"
      ;;
    esac
  done

  COMMAND="$1"
  shift

  OTHER_ARGUMENTS=("$@")

  case "$COMMAND" in
  show)
    STATE_UNIT_LIST=$(/usr/bin/supervisorctl status | awk '{
      state = tolower($2)
      pid = 0
      if (match($0, /pid [0-9]+/)) pid = substr($0, RSTART+4, RLENGTH-4)
      print $1, state, pid
    }')

    shopt -s nullglob
    CONF_FILES=(/etc/supervisor/supervisord.conf /etc/supervisor/conf.d/*.conf)
    shopt -u nullglob

    get_unit_config() {
      local unit="$1" key="$2"
      awk -v unit="$unit" -v key="$key" '
        /^\[program:/ { in_section = ($0 == "[program:" unit "]") }
        in_section && $0 ~ ("^" key "=") { print substr($0, length(key)+2); exit }
      ' "${CONF_FILES[@]}"
    }

    for UNIT in "${OTHER_ARGUMENTS[@]}"; do
      if [ -n "$FIRST_DONE" ]; then
        echo ""
      fi

      UNIT_SERVICE="${UNIT%.service}"

      read -r UNIT_STATE UNIT_PID < <(awk -v u="$UNIT_SERVICE" '$1==u {print $2, $3}' <<< "$STATE_UNIT_LIST")

      for PROPERTY in "${PROPERTIES[@]}"; do
        if [ -z "$VALUE" ]; then
          echo -n "$PROPERTY="
        fi
        case "$PROPERTY" in
        LoadState)
          echo "loaded"
          ;;
        ActiveState)
          [ "$UNIT_STATE" = "running" ] && echo "active" || echo "inactive"
          ;;
        SubState)
          [ "$UNIT_STATE" = "running" ] && echo "running" || echo "dead"
          ;;
        MainPID)
          echo "${UNIT_PID:-0}"
          ;;
        ExecStart)
          get_unit_config "$UNIT_SERVICE" "command"
          ;;
        User)
          get_unit_config "$UNIT_SERVICE" "user"
          ;;
        WorkingDirectory)
          get_unit_config "$UNIT_SERVICE" "directory"
          ;;
        Environment)
          get_unit_config "$UNIT_SERVICE" "environment"
          ;;
        Restart)
          AUTORESTART=$(get_unit_config "$UNIT_SERVICE" "autorestart")
          case "$AUTORESTART" in
            true)       echo "always" ;;
            false | "") echo "no" ;;
            *)          echo "$AUTORESTART" ;;
          esac
          ;;
        UnitFileState)
          CFG=$(get_unit_config "$UNIT_SERVICE" "command")
          [ -n "$CFG" ] && echo "enabled" || echo "disabled"
          ;;
        *)
          echo "unknown"
          ;;
        esac
      done

      FIRST_DONE="1"
    done
    ;;

  status)
    PID_UNIT_LIST=$(/usr/bin/supervisorctl status | awk 'match($0, /pid [0-9]+/) { print substr($0, RSTART+4, RLENGTH-4) " " $1 }')

    for PID in "${OTHER_ARGUMENTS[@]}"; do
      UNIT_NAME=$(awk -v pid="$PID" '$1==pid {print $2}' <<< "$PID_UNIT_LIST")
      if [ -z "$UNIT_NAME" ]; then
        echo "Failed to get unit for PID $PID: PID $PID does not belong to any loaded unit."
        EXIT_CODE=4
      else
        echo "* $UNIT_NAME.service"
      fi
    done
    ;;

  list-units)
    /usr/bin/supervisorctl status | awk '{print $1".service\tloaded\t"(tolower($2)=="running"?"active\trunning":"inactive\tdead")"\t"$1" service"}'
    ;;

  start | stop | restart)
    for UNIT in "${OTHER_ARGUMENTS[@]}"; do
      if [ "$UNIT" = "klipper" ]; then
        # klipper depends on simulavr and klipper_mcu; operate them in dependency order
        /usr/bin/supervisorctl "$COMMAND" simulavr klipper_mcu klipper
      else
        /usr/bin/supervisorctl "$COMMAND" "$UNIT"
      fi
    done
    ;;

  enable | disable | reload | daemon-reload)
    ;;

  *)
    die "Unknown command verb $COMMAND."
    ;;
  esac

  exit $EXIT_CODE
) 200>/tmp/${MY_NAME}.lock
